{
  "name": "library-management-system-lms",
  "version": "0.1.0",
  "private": true,
  "description": "Library Management System (LMS) - Express + Supabase + EJS + Tailwind",
  "type": "commonjs",
  "main": "src/server.js",
  "scripts": {
    "dev": "concurrently -n css,server -c blue,green \"npm:dev:css\" \"npm:dev:server\"",
    "dev:server": "nodemon src/server.js",
    "dev:css": "tailwindcss -i ./src/styles/tailwind.css -o ./src/public/css/app.css --watch",
    "start": "node src/server.js",
    "build:css": "tailwindcss -i ./src/styles/tailwind.css -o ./src/public/css/app.css",
    "vercel-build": "npm run build:css",
    "watch:css": "tailwindcss -i ./src/styles/tailwind.css -o ./src/public/css/app.css --watch"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.57.0",
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "express-ejs-layouts": "^2.5.1",
    "express-rate-limit": "^7.5.0",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.0",
    "nodemon": "^3.1.4",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10"
  }
}
