<section class="mx-auto max-w-md rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
  <h1 class="text-xl font-semibold tracking-tight text-slate-900">Daftar Anggota Baru</h1>
  <p class="mt-1 text-sm text-slate-600">Bergabung dengan perpustakaan digital kami.</p>

  <form class="mt-6 space-y-4" method="post" action="/register">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <div>
      <label class="text-sm font-medium text-slate-700">Nama</label>
      <input
        name="full_name"
        type="text"
        class="mt-1 w-full rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm shadow-sm focus:border-navy-900 focus:outline-none focus:ring-2 focus:ring-navy-900/20"
      />
    </div>
    <div>
      <label class="text-sm font-medium text-slate-700">Email</label>
      <input
        name="email"
        type="email"
        required
        class="mt-1 w-full rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm shadow-sm focus:border-navy-900 focus:outline-none focus:ring-2 focus:ring-navy-900/20"
      />
    </div>
    <div>
      <label class="text-sm font-medium text-slate-700">Password</label>
      <input
        name="password"
        type="password"
        minlength="8"
        required
        class="mt-1 w-full rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm shadow-sm focus:border-navy-900 focus:outline-none focus:ring-2 focus:ring-navy-900/20"
      />
      <p class="mt-1 text-xs text-slate-500">Minimal 8 karakter.</p>
    </div>

    <button
      type="submit"
      class="inline-flex w-full items-center justify-center rounded-xl bg-navy-900 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-navy-800 focus:outline-none focus:ring-2 focus:ring-navy-900 focus:ring-offset-2"
    >
      Buat Akun
    </button>

    <% if (error) { %>
      <p class="rounded-xl border border-red-200 bg-red-50 px-4 py-2 text-sm text-red-700"><%= error %></p>
    <% } %>
    <p class="text-sm text-slate-600">
      Sudah punya akun?
      <a href="/login" class="font-semibold text-navy-900 hover:underline">Login</a>
    </p>
  </form>
</section>
