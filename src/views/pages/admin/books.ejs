<section class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
  <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <h1 class="text-2xl font-semibold tracking-tight text-slate-900">Books</h1>
      <p class="mt-1 text-sm text-slate-600">Tambah, edit, dan hapus buku.</p>
    </div>
    <div class="flex flex-col gap-2 sm:flex-row sm:items-center">
      <form action="/admin/books" method="get" class="flex gap-2">
        <input
          name="q"
          value="<%= q %>"
          placeholder="Search..."
          class="w-full rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm shadow-sm focus:border-navy-900 focus:outline-none focus:ring-2 focus:ring-navy-900/20 sm:w-64"
        />
        <button
          type="submit"
          class="rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50"
        >
          Search
        </button>
      </form>
      <a
        href="/admin/books/new"
        class="inline-flex items-center justify-center rounded-xl bg-navy-900 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-navy-800"
      >
        + Add Book
      </a>
    </div>
  </div>

  <div class="mt-8 overflow-hidden rounded-2xl border border-slate-200">
    <div class="overflow-x-auto">
      <table class="w-full text-left text-sm">
        <thead class="bg-slate-50 text-xs uppercase tracking-wider text-slate-500">
          <tr>
            <th class="px-6 py-3">Title</th>
            <th class="px-6 py-3">Author</th>
            <th class="px-6 py-3">ISBN</th>
            <th class="px-6 py-3">Category</th>
            <th class="px-6 py-3 text-right">Stock</th>
            <th class="px-6 py-3 text-right">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-200 bg-white">
          <% if (!books || books.length === 0) { %>
            <tr>
              <td class="px-6 py-5 text-slate-600" colspan="6">Belum ada buku.</td>
            </tr>
          <% } %>
          <% (books || []).forEach((b) => { %>
            <tr>
              <td class="px-6 py-5 font-semibold text-slate-900"><%= b.title %></td>
              <td class="px-6 py-5 text-slate-700"><%= b.author %></td>
              <td class="px-6 py-5 font-mono text-xs text-slate-700"><%= b.isbn %></td>
              <td class="px-6 py-5 text-slate-700"><%= (b.categories && b.categories.name) ? b.categories.name : "—" %></td>
              <td class="px-6 py-5 text-right">
                <span class="font-semibold text-slate-900"><%= b.stock_available %></span>
                <span class="text-slate-500">/ <%= b.stock_total %></span>
              </td>
              <td class="px-6 py-5 text-right">
                <div class="flex justify-end gap-2">
                  <a
                    href="/admin/books/<%= b.id %>/edit"
                    class="rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50"
                  >
                    Edit
                  </a>
                  <form action="/admin/books/<%= b.id %>/delete" method="post" onsubmit="return confirm('Delete this book?');">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                    <button
                      type="submit"
                      class="rounded-xl border border-rose-200 bg-rose-50 px-3 py-2 text-sm font-semibold text-rose-700 shadow-sm hover:bg-rose-100"
                    >
                      Delete
                    </button>
                  </form>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</section>
