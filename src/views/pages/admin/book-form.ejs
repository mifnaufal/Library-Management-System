<section class="mx-auto max-w-2xl rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
  <div class="flex items-start justify-between gap-4">
    <div>
      <h1 class="text-2xl font-semibold tracking-tight text-slate-900"><%= mode === "edit" ? "Edit Book" : "Add Book" %></h1>
      <p class="mt-1 text-sm text-slate-600">Kelola metadata buku dan stok.</p>
    </div>
    <a
      href="/admin/books"
      class="rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50"
    >
      Back
    </a>
  </div>

  <% if (error) { %>
    <p class="mt-4 rounded-xl border border-red-200 bg-red-50 px-4 py-2 text-sm text-red-700"><%= error %></p>
  <% } %>

  <form
    class="mt-6 space-y-4"
    method="post"
    action="<%= mode === 'edit' ? `/admin/books/${book.id}/edit` : '/admin/books/new' %>"
  >
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <div>
      <label class="text-sm font-medium text-slate-700">Title</label>
      <input
        name="title"
        value="<%= book?.title || '' %>"
        required
        class="mt-1 w-full rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm shadow-sm focus:border-navy-900 focus:outline-none focus:ring-2 focus:ring-navy-900/20"
      />
    </div>

    <div>
      <label class="text-sm font-medium text-slate-700">Author</label>
      <input
        name="author"
        value="<%= book?.author || '' %>"
        required
        class="mt-1 w-full rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm shadow-sm focus:border-navy-900 focus:outline-none focus:ring-2 focus:ring-navy-900/20"
      />
    </div>

    <div>
      <label class="text-sm font-medium text-slate-700">ISBN</label>
      <input
        name="isbn"
        value="<%= book?.isbn || '' %>"
        required
        class="mt-1 w-full rounded-xl border border-slate-200 bg-white px-4 py-2 font-mono text-sm shadow-sm focus:border-navy-900 focus:outline-none focus:ring-2 focus:ring-navy-900/20"
      />
    </div>

    <div>
      <label class="text-sm font-medium text-slate-700">Category</label>
      <select
        name="category_id"
        class="mt-1 w-full rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm shadow-sm focus:border-navy-900 focus:outline-none focus:ring-2 focus:ring-navy-900/20"
      >
        <option value="">—</option>
        <% (categories || []).forEach((c) => { %>
          <option value="<%= c.id %>" <%= String(book?.category_id || '') === String(c.id) ? "selected" : "" %>><%= c.name %></option>
        <% }) %>
      </select>
    </div>

    <div class="grid gap-4 sm:grid-cols-2">
      <div>
        <label class="text-sm font-medium text-slate-700">Stock Total</label>
        <input
          name="stock_total"
          type="number"
          min="0"
          value="<%= typeof book?.stock_total !== 'undefined' ? book.stock_total : 1 %>"
          required
          class="mt-1 w-full rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm shadow-sm focus:border-navy-900 focus:outline-none focus:ring-2 focus:ring-navy-900/20"
        />
      </div>

      <% if (mode === "edit") { %>
        <div>
          <label class="text-sm font-medium text-slate-700">Stock Available</label>
          <input
            name="stock_available"
            type="number"
            min="0"
            value="<%= typeof book?.stock_available !== 'undefined' ? book.stock_available : 0 %>"
            required
            class="mt-1 w-full rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm shadow-sm focus:border-navy-900 focus:outline-none focus:ring-2 focus:ring-navy-900/20"
          />
        </div>
      <% } %>
    </div>

    <button
      type="submit"
      class="inline-flex w-full items-center justify-center rounded-xl bg-navy-900 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-navy-800 focus:outline-none focus:ring-2 focus:ring-navy-900 focus:ring-offset-2"
    >
      Save
    </button>
  </form>
</section>
