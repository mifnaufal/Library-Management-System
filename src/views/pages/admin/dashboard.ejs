<section class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
  <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <h1 class="text-2xl font-semibold tracking-tight text-slate-900">Admin Dashboard</h1>
      <p class="mt-1 text-sm text-slate-600">Ringkasan sistem & buku populer bulan ini.</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-2 text-xs font-semibold text-slate-700">
      Range: <span class="font-mono"><%= range.from %></span> → <span class="font-mono"><%= range.to %></span>
    </div>
  </div>

  <div class="mt-8 grid gap-6 sm:grid-cols-3">
    <div class="rounded-2xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-xs font-semibold uppercase tracking-wider text-slate-500">Total Books</p>
      <p class="mt-1 text-2xl font-semibold text-slate-900"><%= stats.total_books %></p>
    </div>
    <div class="rounded-2xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-xs font-semibold uppercase tracking-wider text-slate-500">Total Members</p>
      <p class="mt-1 text-2xl font-semibold text-slate-900"><%= stats.total_members %></p>
    </div>
    <div class="rounded-2xl border border-slate-200 bg-slate-50 p-5">
      <p class="text-xs font-semibold uppercase tracking-wider text-slate-500">Transactions (This Month)</p>
      <p class="mt-1 text-2xl font-semibold text-slate-900"><%= stats.tx_this_month %></p>
    </div>
  </div>

  <div class="mt-10 overflow-hidden rounded-2xl border border-slate-200">
    <div class="flex items-center justify-between bg-slate-50 px-4 py-3">
      <span class="text-xs font-semibold uppercase tracking-wider text-slate-600">Top 5 Books (Borrowed)</span>
      <a href="/admin/transactions" class="text-sm font-semibold text-navy-900 hover:underline">View transactions</a>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-left text-sm">
        <thead class="bg-white text-xs uppercase tracking-wider text-slate-500">
          <tr>
            <th class="px-6 py-3">Title</th>
            <th class="px-6 py-3">Author</th>
            <th class="px-6 py-3 text-right">Borrowed</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-200 bg-white">
          <% if (!topBooks || topBooks.length === 0) { %>
            <tr>
              <td class="px-6 py-5 text-slate-600" colspan="3">Belum ada data untuk bulan ini.</td>
            </tr>
          <% } %>
          <% (topBooks || []).forEach((row) => { %>
            <tr>
              <td class="px-6 py-5 font-semibold text-slate-900"><%= row.title %></td>
              <td class="px-6 py-5 text-slate-700"><%= row.author %></td>
              <td class="px-6 py-5 text-right font-semibold text-slate-900"><%= row.borrow_count %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</section>
