<section class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
  <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <h1 class="text-2xl font-semibold tracking-tight text-slate-900">Categories</h1>
      <p class="mt-1 text-sm text-slate-600">Kelola kategori buku.</p>
    </div>
    <form class="flex gap-2" method="post" action="/admin/categories">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <input
        name="name"
        placeholder="New category..."
        required
        class="w-full rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm shadow-sm focus:border-navy-900 focus:outline-none focus:ring-2 focus:ring-navy-900/20 sm:w-72"
      />
      <button
        type="submit"
        class="rounded-xl bg-navy-900 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-navy-800"
      >
        Add
      </button>
    </form>
  </div>

  <% if (error) { %>
    <p class="mt-4 rounded-xl border border-red-200 bg-red-50 px-4 py-2 text-sm text-red-700"><%= error %></p>
  <% } %>

  <div class="mt-8 overflow-hidden rounded-2xl border border-slate-200">
    <table class="w-full text-left text-sm">
      <thead class="bg-slate-50 text-xs uppercase tracking-wider text-slate-500">
        <tr>
          <th class="px-6 py-3">Name</th>
          <th class="px-6 py-3 text-right">Action</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-200 bg-white">
        <% if (!categories || categories.length === 0) { %>
          <tr>
            <td class="px-6 py-5 text-slate-600" colspan="2">Belum ada kategori.</td>
          </tr>
        <% } %>
        <% (categories || []).forEach((c) => { %>
          <tr>
            <td class="px-6 py-5 font-semibold text-slate-900"><%= c.name %></td>
            <td class="px-6 py-5 text-right">
              <form action="/admin/categories/<%= c.id %>/delete" method="post" onsubmit="return confirm('Delete this category?');">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <button
                  type="submit"
                  class="rounded-xl border border-rose-200 bg-rose-50 px-3 py-2 text-sm font-semibold text-rose-700 shadow-sm hover:bg-rose-100"
                >
                  Delete
                </button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>
